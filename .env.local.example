# Copia este archivo como .env para pruebas locales.
# Este modo NO llama Gemini, Google Drive, Google Sheets, Apps Script ni Odoo.

PORT=8080

LOCAL_DEV_MODE=true
LOCAL_DEV_SAVE_FILES=true
LOCAL_DEV_STORAGE_DIR=.local-dev
LOCAL_DEV_MOCK_AI=true
LOCAL_DEV_MOCK_AI_STRICT=true

DOCUMENT_AI_VALIDATION_ENABLED=true
DOCUMENT_AI_VALIDATION_REQUIRED=true
DOCUMENT_AI_VALIDATION_MODE=strict

# No se requiere para LOCAL_DEV_MODE=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3-flash-preview,gemini-flash-latest

# No se requieren para LOCAL_DEV_MODE=true
SPREADSHEET_ID=
DRIVE_PARENT_FOLDER_ID=
CRED_TMP_FOLDER_ID=
TEMPLATE_PRESENTATION_ID=
OUTPUT_FOLDER_ID=
APPS_SCRIPT_WEBAPP_URL=
APPS_SCRIPT_SHARED_SECRET=
CRON_SECRET=local-dev-secret

GOOGLE_MAPS_KEY=

# Archivo Excel local para pruebas y credenciales generadas
LOCAL_RECORDS_DIR=.local-records
LOCAL_RECORDS_EXCEL_NAME=ship_documentos.xlsx

# ===== Google Sheets + Drive archive =====
# true = al guardar completo, sube documentos/credencial a Drive y registra fila en Sheets.
GOOGLE_ARCHIVE_ENABLED=false
# Carpeta padre donde se creará una carpeta por driver.
GOOGLE_DRIVE_PARENT_FOLDER_ID=
# ID del Google Sheet donde se agregará una fila por registro.
SPREADSHEET_ID=
SHEET_NAME=Documentos
# Recomendado en local:
# GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
